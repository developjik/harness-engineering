{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "bash hooks/session-start.sh",
        "description": "세션 시작: 디렉토리 초기화, Git 상태 감지, 로그 기록"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/pre-tool.sh",
            "description": "위험한 Bash 명령어 차단 (rm -rf, sudo 등)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/pre-tool.sh",
            "description": "파일 편집 전 백업 생성"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/post-tool.sh",
            "description": "파일 변경 추적, 해시 기록"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/post-tool.sh",
            "description": "Bash 실행 로깅"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "strategist|architect|engineer|guardian|librarian|debugger|grill-me",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/on-agent-start.sh",
            "description": "에이전트 전환 시 PDCA 단계 추적, 상태 기록"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "strategist|architect|engineer|guardian|librarian|debugger|grill-me",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/on-agent-stop.sh",
            "description": "에이전트 종료 로그 기록"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "type": "command",
        "command": "bash hooks/session-end.sh",
        "description": "세션 종료: 로그 기록, 상태 정리"
      }
    ]
  }
}
