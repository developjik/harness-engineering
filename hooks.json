{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "hooks/setup.sh"
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "hooks/validate-input.sh"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/post-edit.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "architect",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-architect-start.sh"
          }
        ]
      },
      {
        "matcher": "engineer",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-engineer-start.sh"
          }
        ]
      },
      {
        "matcher": "guardian",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-guardian-start.sh"
          }
        ]
      },
      {
        "matcher": "librarian",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-librarian-start.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "architect",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-architect-stop.sh"
          }
        ]
      },
      {
        "matcher": "engineer",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-engineer-stop.sh"
          }
        ]
      },
      {
        "matcher": "guardian",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-guardian-stop.sh"
          }
        ]
      },
      {
        "matcher": "librarian",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-librarian-stop.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "type": "command",
        "command": "hooks/cleanup.sh"
      }
    ]
  }
}
