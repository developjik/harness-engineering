{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "hooks/setup.sh",
        "description": "세션 시작 시 PDCA 워크플로우 환경 초기화"
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "hooks/validate-input.sh",
        "description": "사용자 입력 검증 및 컨텍스트 확인"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/pre-bash.sh",
            "description": "위험한 Bash 명령어 차단 (rm -rf 등)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/pre-edit.sh",
            "description": "파일 편집 전 백업 생성"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/post-edit.sh",
            "description": "파일 편집 후 린트 검사 및 변경 사항 추적"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/post-bash.sh",
            "description": "Bash 명령어 실행 후 결과 로깅"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "architect",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-architect-start.sh",
            "description": "Architect 에이전트 시작 시 설계 컨텍스트 로드"
          }
        ]
      },
      {
        "matcher": "engineer",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-engineer-start.sh",
            "description": "Engineer 에이전트 시작 시 구현 환경 준비"
          }
        ]
      },
      {
        "matcher": "guardian",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-guardian-start.sh",
            "description": "Guardian 에이전트 시작 시 리뷰 기준 로드"
          }
        ]
      },
      {
        "matcher": "librarian",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-librarian-start.sh",
            "description": "Librarian 에이전트 시작 시 문서 템플릿 로드"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "architect",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-architect-stop.sh",
            "description": "Architect 에이전트 종료 시 설계 결과 저장"
          }
        ]
      },
      {
        "matcher": "engineer",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-engineer-stop.sh",
            "description": "Engineer 에이전트 종료 시 구현 결과 커밋"
          }
        ]
      },
      {
        "matcher": "guardian",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-guardian-stop.sh",
            "description": "Guardian 에이전트 종료 시 리뷰 결과 저장"
          }
        ]
      },
      {
        "matcher": "librarian",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-librarian-stop.sh",
            "description": "Librarian 에이전트 종료 시 문서 최종화"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "type": "command",
        "command": "hooks/cleanup.sh",
        "description": "세션 종료 시 임시 파일 정리 및 최종 상태 저장"
      }
    ]
  }
}
