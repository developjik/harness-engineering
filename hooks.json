{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "hooks/setup.sh",
        "description": "세션 시작 로그 기록 및 Git/프로젝트 상태 감지"
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "hooks/validate-input.sh",
        "description": "사용자 입력 길이 기록"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/pre-bash.sh",
            "description": "위험한 Bash 명령어 차단"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/pre-edit.sh",
            "description": "파일 편집 전 백업 생성"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/post-edit.sh",
            "description": "파일 편집 후 변경 추적 및 선택적 린트 실행"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/post-bash.sh",
            "description": "Bash 명령어 실행 페이로드 로깅"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "architect",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-architect-start.sh",
            "description": "Architect 시작 시 현재 에이전트 상태와 PLAN 단계 기록"
          }
        ]
      },
      {
        "matcher": "engineer",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-engineer-start.sh",
            "description": "Engineer 시작 시 현재 에이전트 상태와 DO 단계 기록"
          }
        ]
      },
      {
        "matcher": "guardian",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-guardian-start.sh",
            "description": "Guardian 시작 시 현재 에이전트 상태와 CHECK 단계 기록"
          }
        ]
      },
      {
        "matcher": "librarian",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-librarian-start.sh",
            "description": "Librarian 시작 시 현재 에이전트 상태와 ACT 단계 기록"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "architect",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-architect-stop.sh",
            "description": "Architect 종료 로그 기록"
          }
        ]
      },
      {
        "matcher": "engineer",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-engineer-stop.sh",
            "description": "Engineer 종료 로그 기록"
          }
        ]
      },
      {
        "matcher": "guardian",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-guardian-stop.sh",
            "description": "Guardian 종료 로그 기록"
          }
        ]
      },
      {
        "matcher": "librarian",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/on-librarian-stop.sh",
            "description": "Librarian 종료 로그 기록"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "type": "command",
        "command": "hooks/cleanup.sh",
        "description": "세션 종료 로그 기록"
      }
    ]
  }
}
