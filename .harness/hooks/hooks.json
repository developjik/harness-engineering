{\n  \"hooks\": {\n    \"SessionStart\": {\n      \"description\": \"세션 시작 시 자동으로 실행\",\n      \"triggers\": [\n        \"Initialize state manager\",\n        \"Load previous session if exists\",\n        \"Display current phase info\"\n      ],\n      \"handler\": \"hooks/session-start.js\"\n    },\n    \"UserPromptSubmit\": {\n      \"description\": \"사용자 입력 후 자동으로 실행\",\n      \"triggers\": [\n        \"Detect user intent\",\n        \"Route to appropriate agent\",\n        \"Prepare context\"\n      ],\n      \"handler\": \"hooks/user-prompt-submit.js\"\n    },\n    \"PreToolUse\": {\n      \"description\": \"도구 사용 전 자동으로 실행\",\n      \"triggers\": [\n        \"Validate tool parameters\",\n        \"Check permissions\",\n        \"Prepare context\"\n      ],\n      \"handler\": \"hooks/pre-tool-use.js\"\n    },\n    \"PostToolUse\": {\n      \"description\": \"도구 사용 후 자동으로 실행\",\n      \"triggers\": [\n        \"Process tool results\",\n        \"Update state\",\n        \"Check for next actions\"\n      ],\n      \"handler\": \"hooks/post-tool-use.js\"\n    },\n    \"PhaseTransition\": {\n      \"description\": \"PDCA 단계 전환 시 자동으로 실행\",\n      \"triggers\": [\n        \"Validate phase completion\",\n        \"Archive current phase results\",\n        \"Initialize next phase\"\n      ],\n      \"handler\": \"hooks/phase-transition.js\"\n    },\n    \"SessionEnd\": {\n      \"description\": \"세션 종료 시 자동으로 실행\",\n      \"triggers\": [\n        \"Save final state\",\n        \"Generate summary\",\n        \"Archive session\"\n      ],\n      \"handler\": \"hooks/session-end.js\"\n    }\n  },\n  \"hook_execution_order\": [\n    \"SessionStart\",\n    \"UserPromptSubmit\",\n    \"PreToolUse\",\n    \"PostToolUse\",\n    \"PhaseTransition\",\n    \"SessionEnd\"\n  ],\n  \"global_settings\": {\n    \"max_retries\": 3,\n    \"timeout_ms\": 30000,\n    \"log_level\": \"info\"\n  }\n}\n"
