{\n  \"hooks\": {\n    \"on-project-start\": {\n      \"description\": \"새로운 프로젝트 시작 시 자동으로 실행\",\n      \"trigger\": \"사용자가 프로젝트 설명을 입력했을 때\",\n      \"action\": \"Architect 에이전트를 활성화하여 요구사항 분석 시작\",\n      \"instructions\": \"사용자의 프로젝트 설명을 받아 Architect 에이전트를 호출합니다.\"\n    },\n    \"on-design-complete\": {\n      \"description\": \"설계 문서 작성 완료 시 자동으로 실행\",\n      \"trigger\": \"Architect 에이전트가 설계 문서를 완성했을 때\",\n      \"action\": \"Engineer 에이전트를 활성화하여 구현 시작\",\n      \"instructions\": \"설계 문서를 Engineer 에이전트에게 전달하여 코드 구현을 시작합니다.\"\n    },\n    \"on-implementation-complete\": {\n      \"description\": \"코드 구현 완료 시 자동으로 실행\",\n      \"trigger\": \"Engineer 에이전트가 코드 구현을 완료했을 때\",\n      \"action\": \"Guardian 에이전트를 활성화하여 코드 리뷰 시작\",\n      \"instructions\": \"구현된 코드를 Guardian 에이전트에게 전달하여 코드 리뷰를 수행합니다.\"\n    },\n    \"on-review-complete\": {\n      \"description\": \"코드 리뷰 완료 시 자동으로 실행\",\n      \"trigger\": \"Guardian 에이전트가 코드 리뷰를 완료했을 때\",\n      \"action\": \"Librarian 에이전트를 활성화하여 문서화 시작\",\n      \"instructions\": \"리뷰 결과와 최종 코드를 Librarian 에이전트에게 전달하여 문서화를 진행합니다.\"\n    },\n    \"on-documentation-complete\": {\n      \"description\": \"문서화 완료 시 자동으로 실행\",\n      \"trigger\": \"Librarian 에이전트가 문서화를 완료했을 때\",\n      \"action\": \"PDCA 사이클 완료 및 최종 요약 제시\",\n      \"instructions\": \"전체 PDCA 사이클이 완료되었음을 사용자에게 알리고 최종 요약을 제시합니다.\"\n    },\n    \"on-error\": {\n      \"description\": \"에러 발생 시 자동으로 실행\",\n      \"trigger\": \"어떤 에이전트에서 에러가 발생했을 때\",\n      \"action\": \"에러 내용 기록 및 사용자에게 알림\",\n      \"instructions\": \"에러 내용을 기록하고 사용자에게 알린 후 복구 방법을 제시합니다.\"\n    }\n  },\n  \"hook-execution-order\": [\n    \"on-project-start\",\n    \"on-design-complete\",\n    \"on-implementation-complete\",\n    \"on-review-complete\",\n    \"on-documentation-complete\"\n  ],\n  \"global-settings\": {\n    \"max-retries\": 3,\n    \"timeout-seconds\": 300,\n    \"log-level\": \"info\",\n    \"enable-notifications\": true\n  }\n}\n"
